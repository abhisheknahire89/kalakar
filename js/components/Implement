#### Frontend Phone OTP Code (`js/auth.js`):
```javascript
import { account, ID } from './appwriteClient.js';

// ─── PHONE OTP AUTH ───────────────────────────────────

/**
 * Step 1: Send OTP to phone number
 * @param {string} phone - Format: "+919876543210" (with country code)
 * @returns {Object} token with userId needed for step 2
 */
export async function sendPhoneOTP(phone) {
  try {
    // createPhoneToken sends SMS and returns a token
    // If phone number is new → creates account automatically
    // If phone number exists → sends OTP to existing account
    const token = await account.createPhoneToken(ID.unique(), phone);
    return { success: true, userId: token.userId };
  } catch (error) {
    console.error('Send OTP failed:', error);
    // Handle specific errors
    if (error.code === 429) {
      return { success: false, error: 'Too many attempts. Please wait and try again.' };
    }
    return { success: false, error: 'Failed to send OTP. Please check your number.' };
  }
}

/**
 * Step 2: Verify OTP and create session
 * @param {string} userId - From step 1 response
 * @param {string} otp - 6-digit code from SMS
 * @returns {Object} session object
 */
export async function verifyPhoneOTP(userId, otp) {
  try {
    const session = await account.createSession(userId, otp);
    return { success: true, session };
  } catch (error) {
    console.error('Verify OTP failed:', error);
    if (error.code === 401) {
      return { success: false, error: 'Invalid OTP. Please try again.' };
    }
    if (error.code === 410) {
      return { success: false, error: 'OTP has expired. Please request a new one.' };
    }
    return { success: false, error: 'Verification failed. Please try again.' };
  }
}
```

