// js/auth.js — Complete Authentication Module
import { account, databases, storage, ID, Query, DATABASE_ID, COLLECTIONS, BUCKETS } from './appwriteClient.js';

// ═══════════════════════════════════
// SESSION MANAGEMENT
// ═══════════════════════════════════

/**
 * Check if user has an active session
 * Call this on app load to determine if user is logged in
 */
export async function getCurrentUser() {
  try {
    const user = await account.get();
    return user;
  } catch (error) {
    // No active session — user is not logged in
    return null;
  }
}

/**
 * Check if user has a creator profile (completed onboarding)
 */
export async function getCreatorProfile(userId) {
  try {
    const result = await databases.listDocuments(DATABASE_ID, COLLECTIONS.CREATORS, [
      Query.equal('userId', userId),
      Query.limit(1)
    ]);
    return result.documents.length > 0 ? result.documents[0] : null;
  } catch (error) {
    console.error('Failed to fetch creator profile:', error);
    return null;
  }
}

/**
 * Logout — destroy current session
 */
export async function logout() {
  try {
    await account.deleteSession('current');
    return { success: true };
  } catch (error) {
    console.error('Logout failed:', error);
    return { success: false, error: 'Logout failed.' };
  }
}

// ═══════════════════════════════════
// PHONE OTP AUTHENTICATION
// ═══════════════════════════════════

/**
 * Step 1: Send OTP to phone number
 * Format: "+919876543210" (with +91 country code for India)
 * If phone is new → creates account automatically
 * If phone exists → sends OTP to existing account
 */
export async function sendPhoneOTP(phone) {
  try {
    const token = await account.createPhoneToken(ID.unique(), phone);
    return { success: true, userId: token.userId };
  } catch (error) {
    console.error('Send OTP failed:', error);
    if (error.code === 429) {
      return { success: false, error: 'Too many attempts. Wait 60 seconds and try again.' };
    }
    if (error.code === 400) {
      return { success: false, error: 'Invalid phone number format. Use +91XXXXXXXXXX.' };
    }
    return { success: false, error: 'Failed to send OTP. Please check your number and try again.' };
  }
}

/**
 * Step 2: Verify OTP and create session
 * userId: from sendPhoneOTP response
 * otp: 6-digit code user received via SMS (or mock code for test numbers)
 */
export async function verifyPhoneOTP(userId, otp) {
  try {
    const session = await account.createSession(userId, otp);
    return { success: true, session };
  } catch (error) {
    console.error('Verify OTP failed:', error);
    if (error.code === 401) {
      return { success: false, error: 'Invalid OTP code. Please check and try again.' };
    }
    if (error.code === 410) {
      return { success: false, error: 'OTP expired. Please request a new one.' };
    }
    return { success: false, error: 'Verification failed. Please try again.' };
  }
}

