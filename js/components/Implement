// js/app.js — Application Entry Point
import { navigateTo } from './router.js';
import { getCurrentUser, getCreatorProfile } from './auth.js';
import { initNotificationListener, initMessageListener, fetchUnreadCount } from './api/notifications.js';

let currentUser = null;
let currentProfile = null;

async function boot() {
  // 1. Check if user has an active session
  currentUser = await getCurrentUser();

  if (!currentUser) {
    // No session — show login screen
    navigateTo('login');
    initLoginView();
    return;
  }

  // 2. Check if user has completed onboarding (has a creator profile)
  currentProfile = await getCreatorProfile(currentUser.$id);

  if (!currentProfile) {
    // Logged in but no profile — show onboarding wizard
    navigateTo('onboarding');
    initOnboardingView();
    return;
  }

  // 3. Fully authenticated + onboarded — boot the main app
  initMainApp();
}

function initMainApp() {
  // Show the app shell (nav bars, sidebars)
  document.getElementById('app-shell').classList.add('active');

  // Navigate to Stage (home feed)
  const initialView = location.hash.replace('#', '') || 'stage';
  navigateTo(initialView);

  // Initialize real-time listeners (AFTER auth — they need a session)
  initNotificationListener(currentUser.$id);
  initMessageListener(currentUser.$id);
  fetchUnreadCount(currentUser.$id);

  // Populate nav bar with user info
  updateNavProfile(currentProfile);
}

// Boot the app when DOM is ready
document.addEventListener('DOMContentLoaded', boot);

// Export for use in other modules
export { currentUser, currentProfile };
```

