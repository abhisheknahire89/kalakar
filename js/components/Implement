const DATABASE_ID = 'kalakar_db';

async function init() {
  console.log('🎬 Kalakar — Provisioning Appwrite Backend...\n');

  // ── Step 1: Create Database ──
  try {
    await databases.create(DATABASE_ID, 'Kalakar DB');
