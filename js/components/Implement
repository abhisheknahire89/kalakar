import { account, client, OAuthProvider } from './appwriteClient.js';

// ─── GOOGLE OAuth LOGIN ───────────────────────────────

/**
 * Initiate Google OAuth login
 * Opens Google's consent screen in a popup/redirect
 * After successful auth, user is redirected back to the app with a session
 */
export async function loginWithGoogle() {
  try {
    // createOAuth2Session redirects the user to Google's login page
    // After successful login, Google redirects back to Appwrite
    // Appwrite then redirects back to your app with an active session
    account.createOAuth2Session(
      OAuthProvider.Google,                        // Provider
      'http://localhost:8081/#stage',               // Success redirect URL (your app's home)
      'http://localhost:8081/#login',               // Failure redirect URL
      [
        'openid',
        'https://www.googleapis.com/auth/userinfo.email',
        'https://www.googleapis.com/auth/userinfo.profile'
      ]  // Scopes
    );
    // NOTE: This function redirects the browser — code after this won't execute
    // The user will return to the success URL with an active session
  } catch (error) {
    console.error('Google OAuth failed:', error);
    showToast('Google sign-in failed. Please try again.', 'error');
  }
}

/**
 * Alternative: Google OAuth with popup (if you don't want full redirect)
 * Uses createOAuth2Token for more control
 */
