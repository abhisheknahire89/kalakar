      OAuthProvider.Google,
      'http://localhost:8081/#oauth-callback',  // Callback URL
      'http://localhost:8081/#login'             // Failure URL
    );
    // After the popup closes and redirects to callback:
    // Extract userId and secret from URL params
    // Then create session:
    // const session = await account.createSession(userId, secret);
    return result;
  } catch (error) {
    console.error('Google OAuth popup failed:', error);
    showToast('Google sign-in failed. Please try again.', 'error');
  }
}
