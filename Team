  </div>
  <div class="video-card__meta">
    <img class="avatar" src="..." alt="">
    <div class="meta-text">
      <h3>Ishaan Verma</h3>
      <span class="vouch-badge">Vouched by Rajesh Mapuskar (HOD)</span>
    </div>
    <span class="reliability-score">98%</span>
  </div>
  <div class="video-card__actions">
